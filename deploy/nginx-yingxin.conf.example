# 示例：Nginx 反向代理（HTTPS 终止 + 前端静态 + 后端 API）
# 1. 把 yingxin.example.com 换成真实域名
# 2. ssl_certificate 路径换成 certbot 或云厂商证书
# 3. root 指向前端 npm run build 产物目录 frontend/dist
# 4. 链接：sudo ln -s .../nginx-yingxin.conf /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name yingxin.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name yingxin.example.com;

    ssl_certificate     /etc/letsencrypt/live/yingxin.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yingxin.example.com/privkey.pem;

    root /var/www/yingxin/frontend/dist;
    index index.html;

    client_max_body_size 6m;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location /static/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
    }

    location /_AMapService/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
    }
}
