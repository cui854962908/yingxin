# 复制为 .env 并按本机环境修改（勿提交真实密钥）
# PowerShell: Copy-Item .env.example .env

# --- 数据库 ---
# 本机 PostgreSQL（示例：用户 postgres，库 yingxin）
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@127.0.0.1:5432/yingxin
# Docker 仅 DB 容器：postgresql+psycopg://welcome:welcome@127.0.0.1:5432/welcome_db
# Docker 全栈 backend 容器内：postgresql+psycopg://welcome:welcome@db:5432/welcome_db

# --- JWT ---
JWT_SECRET_KEY=replace-with-long-random-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=168

# --- CORS / 文档 ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EXPOSE_API_DOCS=true

# --- 小信对话（DeepSeek）---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# --- 小信 RAG 嵌入（如 SiliconFlow BAAI/bge-m3）---
EMBED_API_KEY=sk-xxxxxxxxxxxxxxxx

# --- 校园 2D 地图（高德）---
AMAP_WEB_KEY=replace-with-amap-web-js-key
AMAP_SECURITY_JS_CODE=replace-with-amap-security-js-code

# --- 可选 ---
# FAQ_MATCH_MIN_SCORE=8.0
# DOCUMENT_COSINE_THRESHOLD=0.6
# REQUIRE_SECURE_SETTINGS=true
