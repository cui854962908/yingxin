# 复制本文件为 .env 并按本地环境修改（不要将真实密钥提交到 git）
# PowerShell:  Copy-Item .env.example .env

# 必填：数据库连接（本机 dev 用 127.0.0.1:5432；Docker 全栈 backend 容器内改为 @db:5432）
DATABASE_URL=postgresql+psycopg://welcome:welcome@127.0.0.1:5432/welcome_db
# DATABASE_CONNECT_TIMEOUT=90

# 必填：JWT 签发密钥（生产必须替换为足够长的随机串）
JWT_SECRET_KEY=replace-with-long-random-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=168

# 开发时设为 true 可打开 /docs
EXPOSE_API_DOCS=false
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 智能助手 FAQ ---
FAQ_MATCH_MIN_SCORE=8.0

# --- 小信对话：DeepSeek API（必填）---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# DEEPSEEK_CHAT_TIMEOUT_SECONDS=120

# --- 小信嵌入：本地 Ollama bge-m3 ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=bge-m3:latest

# --- 其他 ---
# DOCUMENT_COSINE_THRESHOLD=0.6
# EDGE_TTS_VOICE=zh-CN-XiaoyiNeural
